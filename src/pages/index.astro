---
import { getCollection } from 'astro:content';
import ConstellationScene from '../components/ConstellationScene';

const experiments = await getCollection('experiments');

const experimentData = experiments.map((exp) => ({
  id: exp.id,
  thumbnail: exp.data.thumbnail,
  title: exp.data.title,
}));

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cavalry Lab</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; height: 100%; overflow: hidden; }
    </style>
  </head>
  <body>
    <ConstellationScene
      client:only="react"
      experiments={experimentData}
      baseUrl={baseUrl}
      links={[
        { label: 'Instagram', url: 'https://instagram.com/nwjdesigns' },
        { label: 'Patreon', url: 'https://patreon.com/nwjdesigns' },
        { label: 'Scenery', url: 'https://scenery.video' },
      ]}
      workWithMeUrl="https://nwjdesigns.com/contact"
    />
  </body>
</html>
