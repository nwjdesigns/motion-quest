---
import { getCollection } from 'astro:content';
import { generateThemeScript } from '../lib/theme-script';
import ConstellationScene from '../components/ConstellationScene';

const experiments = await getCollection('experiments');

const experimentData = experiments.map((exp) => ({
  id: exp.id,
  thumbnail: exp.data.thumbnail,
  title: exp.data.title,
}));

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const themeScript = generateThemeScript();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cavalry Lab</title>
    <script set:html={themeScript} />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; height: 100%; overflow: hidden; }
      /* Let the 3D canvas swallow native touch gestures (pinch/drag) so they
         drive OrbitControls instead of browser zoom/scroll on mobile.
         :global() needed: the canvas is React-rendered (client:only) so it
         lacks Astro's scope attribute. */
      :global(canvas) { touch-action: none; }
      :root[data-theme="dark"] {
        --mq-bg: #0a0a0a;
        --mq-text: #eaeaea;
        --mq-text-muted: #999999;
        --mq-panel-bg: rgba(255, 255, 255, 0.06);
        --mq-panel-border: rgba(255, 255, 255, 0.1);
        --mq-accent: #9aff9a;
      }
      :root[data-theme="light"] {
        --mq-bg: #f5f5f5;
        --mq-text: #1a1a1a;
        --mq-text-muted: #666666;
        --mq-panel-bg: rgba(0, 0, 0, 0.04);
        --mq-panel-border: rgba(0, 0, 0, 0.1);
        --mq-accent: #2e7d32;
      }
    </style>
  </head>
  <body>
    <ConstellationScene
      client:only="react"
      experiments={experimentData}
      baseUrl={baseUrl}
      links={[
        { label: 'Instagram', url: 'https://instagram.com/nwjdesigns' },
        { label: 'Patreon', url: 'https://patreon.com/nwjdesigns' },
        { label: 'Scenery', url: 'https://scenery.video' },
      ]}
      workWithMeUrl="https://nwjdesigns.com/contact"
    />
  </body>
</html>
