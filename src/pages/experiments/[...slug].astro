---
import { getCollection } from 'astro:content';
import { buildPlayerUrl } from '../../lib/player';
import { getExperimentNav } from '../../lib/navigation';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allExperiments: experiments },
  }));
}

const { entry, allExperiments } = Astro.props;
const { title, date, description, scene, stripeLink } = entry.data;
const playerUrl = buildPlayerUrl(scene, import.meta.env.BASE_URL.replace(/\/$/, ''));
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const navEntries = allExperiments.map((e: any) => ({ id: e.id, date: e.data.date }));
const { prev, next } = getExperimentNav(navEntries, entry.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Cavalry Lab</title>
    <style>
      * { margin: 0; box-sizing: border-box; }
      html, body { height: 100%; background: #0a0a0a; color: #eaeaea; font-family: system-ui, sans-serif; }
      body { display: flex; flex-direction: column; }
      header {
        padding: 16px 24px;
        display: flex; align-items: baseline; gap: 16px;
        font-family: ui-monospace, Menlo, monospace;
      }
      header h1 { font-size: 16px; font-weight: 500; }
      header .meta { font-size: 12px; color: #888; }
      header .desc { font-size: 13px; color: #aaa; margin-left: auto; }
      .player-wrap { flex: 1; min-height: 0; }
      .player-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
      footer {
        padding: 12px 24px;
        display: flex; align-items: center; gap: 16px;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px;
      }
      footer a {
        color: #9aff9a; text-decoration: none;
      }
      footer a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <header>
      <h1>{title}</h1>
      <span class="meta">{formattedDate}</span>
      <span class="desc">{description}</span>
    </header>
    <div class="player-wrap">
      <iframe src={playerUrl} allow="cross-origin-isolated"></iframe>
    </div>
    <footer>
      <a href={`${import.meta.env.BASE_URL}`}>&larr; Back</a>
      {prev && <a href={`${base}/experiments/${prev}`}>&larr; Prev</a>}
      {next && <a href={`${base}/experiments/${next}`}>Next &rarr;</a>}
      {stripeLink && <a href={stripeLink} target="_blank" rel="noopener">Buy scene file</a>}
    </footer>
  </body>
</html>
