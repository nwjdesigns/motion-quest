---
import { getCollection } from 'astro:content';
import { buildPlayerUrl } from '../../lib/player';
import { getExperimentNav } from '../../lib/navigation';
import { generateThemeScript } from '../../lib/theme-script';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allExperiments: experiments },
  }));
}

const { entry, allExperiments } = Astro.props;
const { title, date, scene, aspectRatio = 16/9, tools = [], license, stripeLink } = entry.data;
const playerUrl = buildPlayerUrl(scene, import.meta.env.BASE_URL.replace(/\/$/, ''));
const dateDay = String(date.getUTCDate()).padStart(2, '0');
const dateRest = `${String(date.getUTCMonth() + 1).padStart(2, '0')}${date.getUTCFullYear()}`;

const navEntries = allExperiments.map((e: any) => ({ id: e.id, date: e.data.date }));
const { prev, next } = getExperimentNav(navEntries, entry.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const themeScript = generateThemeScript();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Cavalry Lab</title>
    <script set:html={themeScript} />
    <style>
      * { margin: 0; box-sizing: border-box; }
      html, body { height: 100%; overflow: hidden; }
      :root[data-theme="dark"] {
        --mq-bg: #0a0a0a;
        --mq-text: #eaeaea;
        --mq-text-muted: #aaaaaa;
        --mq-accent: #9aff9a;
        --mq-panel-bg: rgba(14, 14, 14, 0.78);
        --mq-panel-border: rgba(255, 255, 255, 0.12);
        --mq-panel-hover: rgba(255, 255, 255, 0.1);
        --mq-divider: rgba(255, 255, 255, 0.1);
      }
      :root[data-theme="light"] {
        --mq-bg: #f5f5f5;
        --mq-text: #1a1a1a;
        --mq-text-muted: #5a5a5a;
        --mq-accent: #2e7d32;
        --mq-panel-bg: rgba(248, 248, 248, 0.82);
        --mq-panel-border: rgba(0, 0, 0, 0.12);
        --mq-panel-hover: rgba(0, 0, 0, 0.06);
        --mq-divider: rgba(0, 0, 0, 0.08);
      }
      html, body {
        background: var(--mq-bg);
        color: var(--mq-text);
        font-family: system-ui, -apple-system, sans-serif;
      }

      .page {
        --player-w: min(calc(100vw - 24px), calc((100vh - 16px) * var(--aspect-ratio)));
        --content-right: min(calc(var(--player-w) + 24px), 60vw);
      }

      .stage {
        position: fixed; inset: 8px 8px 8px 16px;
        display: flex; align-items: center; justify-content: flex-end;
      }
      .stage-inner {
        max-width: min(100%, calc((100vh - 16px) * var(--aspect-ratio)));
        max-height: min(100%, calc((100vw - 24px) / var(--aspect-ratio)));
        aspect-ratio: var(--aspect-ratio);
        height: 100%;
        border-radius: 12px; overflow: hidden;
      }
      .stage-inner iframe {
        width: 100%; height: 100%; border: none; display: block;
        touch-action: manipulation;
      }

      /* top bar */
      .topbar {
        position: fixed; top: 0; left: 0; right: var(--content-right);
        height: 64px; padding: 0 28px;
        display: flex; align-items: center;
        z-index: 20;
      }
      .brand {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 24px; font-weight: 500; letter-spacing: 0.01em;
        color: var(--mq-text);
      }
      .brand sup { font-size: 0.46em; font-weight: 400; }
      .topnav {
        position: absolute; left: 50%; transform: translateX(-50%);
        display: flex; align-items: center; gap: 4px;
      }
      .navlink, .toggle {
        font-family: inherit; font-size: 13px; color: var(--mq-text-muted);
        text-decoration: none; background: transparent; border: none; cursor: pointer;
        padding: 6px 12px; border-radius: 6px;
        transition: all 0.2s ease; white-space: nowrap;
      }
      .navlink:hover, .toggle:hover {
        color: var(--mq-text); background: var(--mq-panel-hover);
      }
      .toggle { margin-left: auto; }

      /* title card */
      .panel {
        position: fixed; top: 50%; left: 28px;
        transform: translateY(-50%);
        background: var(--mq-panel-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--mq-panel-border);
        border-radius: 14px;
        opacity: 0.9; transition: opacity 0.3s ease;
        z-index: 10;
        padding: 24px 28px; max-width: 348px;
        display: flex; flex-direction: column; gap: 18px;
      }
      .panel:hover { opacity: 1; }
      @media (hover: none) { .panel { opacity: 1; } }

      .panel h1 {
        font-size: 28px; font-weight: 600;
        letter-spacing: -0.02em; line-height: 1.05;
      }

      .tools-list { display: flex; flex-wrap: wrap; gap: 6px; }
      .tool-tag {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--mq-text-muted);
        padding: 4px 9px; border-radius: 5px;
        border: 1px solid var(--mq-panel-border);
      }

      .meta-row {
        display: flex; align-items: baseline;
        justify-content: space-between; gap: 16px;
      }
      .date {
        font-family: inherit;
        font-size: 13px; letter-spacing: 0.01em;
        color: var(--mq-text-muted);
      }
      .date b { color: var(--mq-text); font-weight: 700; }
      .made-in { font-size: 12px; color: var(--mq-text-muted); white-space: nowrap; }

      .actions {
        display: flex; flex-direction: column; gap: 8px;
        border-top: 1px solid var(--mq-divider); padding-top: 14px;
      }
      .download-link, .buy-link {
        font-size: 12px; text-decoration: none;
        font-weight: 500; transition: opacity 0.2s ease;
      }
      .download-link { color: var(--mq-text); }
      .download-link:hover, .buy-link:hover { opacity: 0.7; }
      .buy-link { color: var(--mq-accent); }
      .license-note {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 10px; color: var(--mq-text-muted); line-height: 1.4;
      }

      /* footer bar */
      .footbar {
        position: fixed; bottom: 0; left: 0; right: var(--content-right);
        height: 56px; padding: 0 28px;
        display: flex; align-items: center; justify-content: space-between;
        font-size: 12px; color: var(--mq-text-muted);
        z-index: 20;
      }

      @media (max-width: 600px) {
        .topbar, .footbar { right: 0; }
        .topnav { position: static; transform: none; margin: 0 auto; }
        .panel { left: 16px; right: 16px; max-width: none; padding: 18px 18px; }
        .panel h1 { font-size: 28px; }
      }
    </style>
  </head>
  <body>
    <main class="page" style={`--aspect-ratio: ${aspectRatio};`}>
      <header class="topbar">
        <span class="brand">MQ<sup>&trade;</sup></span>
        <nav class="topnav">
          <a class="navlink" href={`${import.meta.env.BASE_URL}`}>Gallery</a>
          {prev && <a class="navlink" href={`${base}/experiments/${prev}`}>&larr; Prev</a>}
          {next && <a class="navlink" href={`${base}/experiments/${next}`}>Next &rarr;</a>}
        </nav>
        <button class="toggle" id="theme-toggle" aria-label="Toggle theme">Dark</button>
      </header>

      <div class="stage">
        <div class="stage-inner">
          <iframe src={playerUrl} allow="cross-origin-isolated" id="cavalry-player"></iframe>
        </div>
      </div>

      <div class="panel">
        <h1>{title}</h1>

        {tools.length > 0 && (
          <div class="tools-list">
            {tools.map((tool: string) => <span class="tool-tag">{tool}</span>)}
          </div>
        )}

        <div class="meta-row">
          <span class="date"><b>{dateDay}</b>{dateRest}</span>
          <span class="made-in">Made in Cavalry</span>
        </div>

        {(license || stripeLink) && (
          <div class="actions">
            {license && (
              <Fragment>
                <a class="download-link" href={`${base}/cavalry/scenes/${scene}`} download>Download .cv</a>
                <span class="license-note">{license}</span>
              </Fragment>
            )}
            {stripeLink && (
              <a class="buy-link" href={stripeLink} target="_blank" rel="noopener">Buy scene file</a>
            )}
          </div>
        )}
      </div>

      <footer class="footbar">
        <span>&copy;2026 Noah Webster-James</span>
        <span>Creative Tech</span>
      </footer>
    </main>

    <script>
      const iframe = document.getElementById('cavalry-player') as HTMLIFrameElement | null;
      const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;

      const currentTheme = () =>
        document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';

      const syncToggleLabel = () => {
        if (toggle) toggle.textContent = currentTheme() === 'dark' ? 'Light' : 'Dark';
      };

      const postTheme = () => {
        iframe?.contentWindow?.postMessage({ type: 'theme-change', theme: currentTheme() }, '*');
      };

      syncToggleLabel();
      iframe?.addEventListener('load', postTheme);

      toggle?.addEventListener('click', () => {
        const next = currentTheme() === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mq-theme', next);
        syncToggleLabel();
        postTheme();
      });
    </script>
  </body>
</html>
