---
import { getCollection } from 'astro:content';
import { buildPlayerUrl } from '../../lib/player';
import { getExperimentNav } from '../../lib/navigation';
import { generateThemeScript } from '../../lib/theme-script';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allExperiments: experiments },
  }));
}

const { entry, allExperiments } = Astro.props;
const { title, date, description, scene, stripeLink } = entry.data;
const playerUrl = buildPlayerUrl(scene, import.meta.env.BASE_URL.replace(/\/$/, ''));
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const navEntries = allExperiments.map((e: any) => ({ id: e.id, date: e.data.date }));
const { prev, next } = getExperimentNav(navEntries, entry.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const themeScript = generateThemeScript();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Cavalry Lab</title>
    <script set:html={themeScript} />
    <style>
      * { margin: 0; box-sizing: border-box; }
      html, body { height: 100%; font-family: system-ui, sans-serif; }
      html, body { overflow-x: hidden; }
      :root[data-theme="dark"] {
        --mq-bg: #0a0a0a;
        --mq-text: #eaeaea;
        --mq-text-muted: #999999;
        --mq-accent: #9aff9a;
      }
      :root[data-theme="light"] {
        --mq-bg: #f5f5f5;
        --mq-text: #1a1a1a;
        --mq-text-muted: #666666;
        --mq-accent: #2e7d32;
      }
      html, body { background: var(--mq-bg); color: var(--mq-text); }
      body { display: flex; flex-direction: column; }
      header {
        padding: 16px 24px;
        display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;
        font-family: ui-monospace, Menlo, monospace;
      }
      header h1 { font-size: 16px; font-weight: 500; }
      header .meta { font-size: 12px; color: var(--mq-text-muted); }
      header .desc {
        font-size: 13px; color: var(--mq-text-muted); margin-left: auto;
        min-width: 0; overflow-wrap: anywhere;
      }
      .player-wrap { flex: 1; min-height: 0; }
      .player-wrap iframe {
        width: 100%; height: 100%; border: none; display: block;
        touch-action: manipulation;
      }
      footer {
        padding: 12px 24px;
        display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px;
      }
      footer a {
        color: var(--mq-accent); text-decoration: none;
      }
      footer a:hover { text-decoration: underline; }

      @media (max-width: 600px) {
        header {
          padding: 12px 16px;
          flex-direction: column; align-items: flex-start; gap: 4px;
        }
        header .desc { margin-left: 0; }
        footer { padding: 10px 16px; gap: 12px; }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>{title}</h1>
      <span class="meta">{formattedDate}</span>
      <span class="desc">{description}</span>
    </header>
    <div class="player-wrap">
      <iframe src={playerUrl} allow="cross-origin-isolated" id="cavalry-player"></iframe>
    </div>
    <footer>
      <a href={`${import.meta.env.BASE_URL}`}>&larr; Back</a>
      {prev && <a href={`${base}/experiments/${prev}`}>&larr; Prev</a>}
      {next && <a href={`${base}/experiments/${next}`}>Next &rarr;</a>}
      {stripeLink && <a href={stripeLink} target="_blank" rel="noopener">Buy scene file</a>}
    </footer>
    <script>
      const iframe = document.getElementById('cavalry-player') as HTMLIFrameElement;
      if (iframe) {
        const theme = document.documentElement.getAttribute('data-theme') || 'dark';
        iframe.addEventListener('load', () => {
          iframe.contentWindow?.postMessage({ type: 'theme-change', theme }, '*');
        });
      }
    </script>
  </body>
</html>
