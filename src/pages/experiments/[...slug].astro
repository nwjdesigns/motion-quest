---
import { getCollection } from 'astro:content';
import { buildPlayerUrl } from '../../lib/player';
import { getExperimentNav } from '../../lib/navigation';
import { generateThemeScript } from '../../lib/theme-script';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allExperiments: experiments },
  }));
}

const { entry, allExperiments } = Astro.props;
const { title, date, description, scene, aspectRatio = 16/9, tools = [], cavalryVersion, license, stripeLink } = entry.data;
const playerUrl = buildPlayerUrl(scene, import.meta.env.BASE_URL.replace(/\/$/, ''));
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const navEntries = allExperiments.map((e: any) => ({ id: e.id, date: e.data.date }));
const { prev, next } = getExperimentNav(navEntries, entry.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const themeScript = generateThemeScript();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Cavalry Lab</title>
    <script set:html={themeScript} />
    <style>
      * { margin: 0; box-sizing: border-box; }
      html, body { height: 100%; overflow: hidden; }
      :root[data-theme="dark"] {
        --mq-bg: #0a0a0a;
        --mq-text: #eaeaea;
        --mq-text-muted: #aaaaaa;
        --mq-accent: #9aff9a;
        --mq-panel-bg: rgba(14, 14, 14, 0.78);
        --mq-panel-border: rgba(255, 255, 255, 0.12);
        --mq-panel-hover: rgba(255, 255, 255, 0.1);
        --mq-divider: rgba(255, 255, 255, 0.1);
      }
      :root[data-theme="light"] {
        --mq-bg: #f5f5f5;
        --mq-text: #1a1a1a;
        --mq-text-muted: #5a5a5a;
        --mq-accent: #2e7d32;
        --mq-panel-bg: rgba(248, 248, 248, 0.82);
        --mq-panel-border: rgba(0, 0, 0, 0.12);
        --mq-panel-hover: rgba(0, 0, 0, 0.06);
        --mq-divider: rgba(0, 0, 0, 0.08);
      }
      html, body {
        background: var(--mq-bg);
        color: var(--mq-text);
        font-family: system-ui, -apple-system, sans-serif;
      }

      .stage {
        position: fixed; inset: 8px 8px 8px 16px;
        display: flex; align-items: center; justify-content: flex-end;
      }
      .stage-inner {
        max-width: min(100%, calc((100vh - 16px) * var(--aspect-ratio)));
        max-height: min(100%, calc((100vw - 24px) / var(--aspect-ratio)));
        aspect-ratio: var(--aspect-ratio);
        height: 100%;
        border-radius: 12px; overflow: hidden;
      }
      .stage-inner iframe {
        width: 100%; height: 100%; border: none; display: block;
        touch-action: manipulation;
      }

      .panel {
        position: fixed;
        top: 50%; left: 24px;
        transform: translateY(-50%);
        background: var(--mq-panel-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--mq-panel-border);
        border-radius: 12px;
        opacity: 0.82;
        transition: opacity 0.3s ease;
        z-index: 10;
        padding: 16px 20px; max-width: 340px;
        display: flex; flex-direction: column; gap: 14px;
      }
      .panel:hover { opacity: 1; }
      @media (hover: none) { .panel { opacity: 1; } }

      .panel-head { display: flex; flex-direction: column; gap: 6px; }
      .panel-head h1 { font-size: 18px; font-weight: 500; letter-spacing: -0.01em; }
      .panel-head .date {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px; color: var(--mq-text-muted);
      }
      .panel-head .desc {
        font-size: 13px; color: var(--mq-text-muted);
        line-height: 1.5; padding-top: 2px;
      }

      .meta-label {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 10px; font-weight: 500;
        letter-spacing: 0.06em; text-transform: uppercase;
        color: var(--mq-text-muted);
      }

      .made-with {
        display: flex; flex-direction: column; gap: 8px;
      }
      .tools-list {
        display: flex; flex-wrap: wrap; gap: 6px;
      }
      .tool-tag {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 11px; color: var(--mq-text-muted);
        padding: 3px 8px; border-radius: 4px;
        border: 1px solid var(--mq-panel-border);
      }

      .actions {
        display: flex; flex-direction: column; gap: 8px;
      }
      .download-link, .buy-link {
        font-size: 12px; text-decoration: none;
        font-weight: 500; transition: opacity 0.2s ease;
        padding: 0;
      }
      .download-link { color: var(--mq-text); }
      .download-link:hover, .buy-link:hover { opacity: 0.7; }
      .license-note {
        font-family: ui-monospace, Menlo, monospace;
        font-size: 10px; color: var(--mq-text-muted);
        line-height: 1.4;
      }

      .nav-foot-wrap {
        display: flex; flex-direction: column; gap: 10px;
        border-top: 1px solid var(--mq-divider); padding-top: 12px;
      }
      .nav-row { display: flex; align-items: center; gap: 4px; }
      .nav-row a, .nav-row button {
        font-family: inherit; font-size: 12px; color: var(--mq-text-muted);
        text-decoration: none; background: transparent; border: none; cursor: pointer;
        padding: 5px 10px; border-radius: 6px; transition: all 0.2s ease; white-space: nowrap;
      }
      .nav-row a:hover, .nav-row button:hover {
        color: var(--mq-text); background: var(--mq-panel-hover);
      }
      .nav-row .toggle { margin-left: auto; }
      .buy-link { color: var(--mq-accent); }

      @media (max-width: 600px) {
        .panel { left: 16px; right: 16px; max-width: none; padding: 12px 16px; }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <div class="stage-inner" style={`--aspect-ratio: ${aspectRatio};`}>
        <iframe src={playerUrl} allow="cross-origin-isolated" id="cavalry-player"></iframe>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <h1>{title}</h1>
        <span class="date">{formattedDate}</span>
        {description && <span class="desc">{description}</span>}
      </div>

      {tools.length > 0 && (
        <div class="made-with">
          <span class="meta-label">
            {cavalryVersion ? `Made in Cavalry ${cavalryVersion} with` : 'Made with'}
          </span>
          <div class="tools-list">
            {tools.map((tool: string) => <span class="tool-tag">{tool}</span>)}
          </div>
        </div>
      )}

      {(license || stripeLink) && (
        <div class="actions">
          {license && (
            <Fragment>
              <a class="download-link" href={`${base}/cavalry/scenes/${scene}`} download>Download .cv</a>
              <span class="license-note">{license}</span>
            </Fragment>
          )}
          {stripeLink && (
            <a class="buy-link" href={stripeLink} target="_blank" rel="noopener">Buy scene file</a>
          )}
        </div>
      )}

      <div class="nav-foot-wrap">
        <div class="nav-row">
          <a href={`${import.meta.env.BASE_URL}`}>&larr; Back</a>
          {prev && <a href={`${base}/experiments/${prev}`}>&larr; Prev</a>}
          {next && <a href={`${base}/experiments/${next}`}>Next &rarr;</a>}
          <button class="toggle" id="theme-toggle" aria-label="Toggle theme">Light</button>
        </div>
      </div>
    </div>

    <script>
      const iframe = document.getElementById('cavalry-player') as HTMLIFrameElement | null;
      const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;

      const currentTheme = () =>
        document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';

      const syncToggleLabel = () => {
        if (toggle) toggle.textContent = currentTheme() === 'dark' ? 'Light' : 'Dark';
      };

      const postTheme = () => {
        iframe?.contentWindow?.postMessage({ type: 'theme-change', theme: currentTheme() }, '*');
      };

      syncToggleLabel();
      iframe?.addEventListener('load', postTheme);

      toggle?.addEventListener('click', () => {
        const next = currentTheme() === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mq-theme', next);
        syncToggleLabel();
        postTheme();
      });
    </script>
  </body>
</html>
